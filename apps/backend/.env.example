# Makima Agent Backend - local secrets template
# Copy this file to .env and fill in real values locally.
# Do not commit the real .env file.

# LLM
MAKIMA_LLM_API_KEY=sk-your-api-key-here
MAKIMA_LLM_API_BASE=https://api.deepseek.com
MAKIMA_LLM_MODEL=deepseek-v4-flash

# General
MAKIMA_APP_NAME=makima-agent
MAKIMA_DEBUG=true
MAKIMA_ENVIRONMENT=development
MAKIMA_API_SECRET_KEY=replace-with-a-long-random-secret
MAKIMA_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Database
MAKIMA_DATABASE_URL=sqlite+aiosqlite:///./makima.db

# Redis
MAKIMA_REDIS_URL=

# Orchestrator
MAKIMA_ORCHESTRATOR_MAX_STEPS=50
MAKIMA_ORCHESTRATOR_TIMEOUT=300

# Memory
MAKIMA_MEMORY_ENABLED=false
MAKIMA_MEM0_EMBEDDING_MODEL=text-embedding-3-small
MAKIMA_MEM0_VECTOR_STORE=pgvector

# Knowledge
MAKIMA_KNOWLEDGE_ENABLED=true
MAKIMA_RAG_CHUNK_SIZE=512
MAKIMA_RAG_CHUNK_OVERLAP=50
MAKIMA_RAG_TOP_K=5

# Observability / API
MAKIMA_LOG_LEVEL=INFO
MAKIMA_API_TIMEOUT=30.0

# CLI auth
MAKIMA_CLI_USERNAME=your-local-admin
MAKIMA_CLI_PASSWORD=replace-with-a-strong-local-password

# Fish Audio
MAKIMA_FISH_AUDIO_KEY=your-fish-audio-key
MAKIMA_FISH_AUDIO_REFERENCE_ID=your-fish-audio-reference-id
