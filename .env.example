# ═══════════════════════════════════════════════
# Makima Agent Backend - 环境变量配置
# ═══════════════════════════════════════════════
# 复制本文件为 .env 并按需修改

# ── LLM 配置 ──────────────────────────────────
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ── PostgreSQL ─────────────────────────────────
POSTGRES_USER=makima
POSTGRES_PASSWORD=makima
POSTGRES_DB=makima
POSTGRES_PORT=5432

# ── Redis ──────────────────────────────────────
REDIS_PORT=6379

# ── API Gateway ────────────────────────────────
API_GATEWAY_PORT=8000
API_SECRET_KEY=change-me-to-a-random-string
MAKIMA_API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ── Agent Orchestrator ─────────────────────────
ORCHESTRATOR_MAX_STEPS=50
ORCHESTRATOR_TIMEOUT=300

# ── Memory Service (Mem0) ──────────────────────
MEM0_EMBEDDING_MODEL=text-embedding-3-small
MEM0_VECTOR_STORE=pgvector

# ── Knowledge Service ──────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# ── Tool Runtime ───────────────────────────────
TOOL_SANDBOX_ENABLED=true
TOOL_TIMEOUT=60
