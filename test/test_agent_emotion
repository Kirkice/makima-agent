#!/usr/bin/env python3
"""
Part 2: Agent 端情绪标签生成和转发测试

测试流程:
1. 检查后端是否正确生成了 [emotion:xxx] 标签
2. 检查后端是否正确解析了标签
3. 检查 SSE 事件中是否包含 animation 事件
4. 检查 Rust 桌面应用是否正确转发到 WebSocket

依赖: pip install requests sseclient-py
"""

import requests
import json
import sseclient
import sys
from datetime import datetime


def test_emotion_tag_generation():
    """测试后端是否生成了情绪标签"""
    
    print("=" * 60)
    print("Part 2: Agent 端情绪标签测试")
    print("=" * 60)
    print(f"时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print()
    
    # 后端 API 地址
    backend_url = "http://127.0.0.1:8000"
    
    print("步骤 1: 检查后端服务是否运行")
    print("-" * 60)
    
    try:
        health_url = f"{backend_url}/health"
        response = requests.get(health_url, timeout=5)
        
        if response.status_code == 200:
            print(f"✓ 后端服务运行正常: {health_url}")
            print(f"  响应: {response.json()}")
        else:
            print(f"✗ 后端服务返回错误: {response.status_code}")
            print(f"  响应: {response.text}")
            return False
            
    except requests.exceptions.ConnectionError:
        print(f"✗ 无法连接到后端服务: {health_url}")
        print(f"  请确保后端已启动: cd apps/backend && python -m uvicorn makima.app:app")
        return False
    except Exception as e:
        print(f"✗ 检查后端服务时出错: {e}")
        return False
    
    print()
    print("步骤 2: 发送测试消息并检查情绪标签")
    print("-" * 60)
    
    # 测试消息
    test_messages = [
        "你好，玛奇玛！今天天气真好。",
        "我不喜欢这个主意。",
        "让我想想这个问题...",
        "太棒了！这个解决方案很完美！",
    ]
    
    # 需要认证 token
    # 这里使用环境变量或硬编码的测试 token
    # 实际使用时需要替换为真实的 token
    auth_token = input("\n请输入认证 token (或按回车跳过此测试): ").strip()
    
    if not auth_token:
        print("\n⚠ 跳过测试：未提供认证 token")
        print("  你可以手动运行以下命令获取 token:")
        print("  curl -X POST http://127.0.0.1:8000/api/auth/login \\")
        print("       -H 'Content-Type: application/json' \\")
        print("       -d '{\"username\": \"test\", \"password\": \"test\"}'")
        return False
    
    headers = {
        "Authorization": f"Bearer {auth_token}",
        "Content-Type": "application/json",
    }
    
    for i, message in enumerate(test_messages, 1):
        print(f"\n[{i}/{len(test_messages)}] 发送消息: {message}")
        
        try:
            # 发送消息到后端
            chat_url = f"{backend_url}/api/chat"
            payload = {
                "message": message,
                "session_id": "test-session-emotion",
            }
            
            response = requests.post(
                chat_url,
                headers=headers,
                json=payload,
                stream=True,
                timeout=30
            )
            
            if response.status_code != 200:
                print(f"  ✗ 请求失败: {response.status_code}")
                print(f"    响应: {response.text}")
                continue
            
            # 解析 SSE 流
            print(f"  ✓ 请求成功，解析 SSE 流...")
            
            client = sseclient.SSEClient(response)
            
            emotion_events = []
            message_events = []
            
            for event in client.events():
                event_type = event.event
                event_data = event.data
                
                # 打印所有事件（用于调试）
                print(f"    事件: {event_type}")
                
                try:
                    data = json.loads(event_data)
                    print(f"      数据: {json.dumps(data, ensure_ascii=False, indent=6)}")
                    
                    # 检查是否是 animation 事件
                    if event_type == "animation":
                        emotion_events.append(data)
                        print(f"      ✓ 发现 emotion 事件: {data}")
                    
                    # 检查是否是 message 事件
                    elif event_type == "message":
                        message_events.append(data)
                        # 检查消息内容中是否包含 [emotion:xxx] 标签
                        if "content" in data:
                            content = data["content"]
                            if "[emotion:" in content:
                                print(f"      ⚠ 消息中包含原始 emotion 标签: {content}")
                    
                except json.JSONDecodeError:
                    print(f"      ⚠ 无法解析 JSON: {event_data}")
            
            # 总结
            print(f"\n  结果:")
            print(f"    - 收到 {len(message_events)} 个 message 事件")
            print(f"    - 收到 {len(emotion_events)} 个 animation 事件")
            
            if emotion_events:
                print(f"    ✓ 成功提取到情绪标签:")
                for evt in emotion_events:
                    print(f"      - {evt}")
            else:
                print(f"    ✗ 未找到 animation 事件")
                print(f"    可能的原因:")
                print(f"      1. LLM 没有生成 [emotion:xxx] 标签")
                print(f"      2. 后端没有正确解析标签")
                print(f"      3. 后端没有发送 animation SSE 事件")
        
        except Exception as e:
            print(f"  ✗ 测试失败: {e}")
            import traceback
            traceback.print_exc()
    
    print()
    print("-" * 60)
    print("测试完成")
    print()
    print("下一步:")
    print("  1. 如果看到 animation 事件 → Agent 端正常工作，检查 Rust 转发")
    print("  2. 如果没有 animation 事件 → 检查后端 emotion_parser.py")
    print("  3. 如果消息中包含 [emotion:xxx] → 后端没有正确解析标签")
    
    return True


def test_rust_websocket_forward():
    """测试 Rust 是否正确转发到 WebSocket"""
    
    print("\n" + "=" * 60)
    print("Part 2b: Rust WebSocket 转发测试")
    print("=" * 60)
    print()
    
    print("请手动检查:")
    print("  1. 启动 Rust 桌面应用: cd apps/desktop-egui && cargo run")
    print("  2. 观察终端输出，应该看到:")
    print("     - WebSocket Bridge listening on ws://127.0.0.1:9001")
    print("     - 收到 SSE 事件后: Broadcasting animation command")
    print()
    print("  3. 如果看到 Broadcasting 但 WebGL 没有播放:")
    print("     - 检查 WebSocket 客户端是否连接")
    print("     - 检查消息格式是否正确")
    print()


if __name__ == "__main__":
    # 检查依赖
    try:
        import requests
        import sseclient
    except ImportError:
        print("错误: 缺少依赖库")
        print("请运行: pip install requests sseclient-py")
        sys.exit(1)
    
    # 运行测试
    test_emotion_tag_generation()
    test_rust_websocket_forward()